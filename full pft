n train/test split.\n    \n    Returns:\n        train_df, test_df  (both with columns: src=fr, tgt=en)\n    \"\"\"\n    df = pd.read_csv(path)\n\n    # Keep only French → English\n    df = df[[\"fr\", \"en\"]].dropna().drop_duplicates().reset_index(drop=True)\n\n    # Optional subsampling\n    if sample_frac < 1.0:\n        df = df.sample(frac=sample_frac, random_state=SEED).reset_index(drop=True)\n\n    # Clean\n    df[\"fr\"] = df[\"fr\"].apply(clean_text)\n    df[\"en\"] = df[\"en\"].apply(clean_text)\n\n    # Rename to match your pipeline\n    df = df.rename(columns={\"fr\": \"src\", \"en\": \"tgt\"})\n\n    # Train/test split\n    train_df, test_df = train_test_split(\n        df,\n        test_size=test_size,\n        random_state=SEED,\n        shuffle=True\n    )\n\n    # Reset indices (important for dataloaders later)\n    train_df = train_df.reset_index(drop=True)\n    test_df = test_df.reset_index(drop=True)\n\n    return train_df, test_df\n\n\n# Usage\nfinetune_train_df, finetune_test_df = load_juridia_fr_en(\n    CFG[\"juridia_train\"],\n    sample_frac=CFG[\"finetune_sample_frac\"],\n    test_size=0.1\n)\n\nprint(\"Train shape:\", finetune_train_df.shape)\nprint(\"Test shape:\", finetune_test_df.shape)\nprint(finetune_train_df.head(3))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T16:33:59.215250Z","iopub.execute_input":"2026-04-19T16:33:59.215584Z","iopub.status.idle":"2026-04-19T16:34:19.519086Z","shell.execute_reply.started":"2026-04-19T16:33:59.215555Z","shell.execute_reply":"2026-04-19T16:34:19.518338Z"}},"outputs":[{"name":"stdout","text":"Train shape: (317781, 2)\nTest shape: (35309, 2)\n                                                 src  \\\n0  malgré les progrès considérables réalisés dans...   \n1  - le président , le premier ministre , le prés...   \n2  le département des délits économiques et finan...   \n\n                                                 tgt  \n0  most women in developing countries first estab