mask) for head in self.heads], dim=-1)\n        return self.lin(z)\n\nclass FeedForward(nn.Module):\n    def __init__(self, d_model, d_ff):\n        super().__init__()\n        self.ffn1 = nn.Linear(d_model, d_ff)\n        self.ffn2 = nn.Linear(d_ff, d_model)\n\n    def forward(self, x):\n        return self.ffn2(F.relu(self.ffn1(x)))\n\nclass EncoderLayer(nn.Module):\n    def __init__(self, n_heads, d_model, d_k, d_v, d_ff):\n        super().__init__()\n        self.mha = MultiHeadAttention(n_heads, d_model, d_k, d_v)\n        self.ffn = FeedForward(d_model, d_ff)\n        self.ln1 = nn.LayerNorm(d_model)\n        self.ln2 = nn.LayerNorm(d_model)\n\n    def forward(self, x, src_mask=None):\n        x = self.ln1(x + self.mha(x, x, x, src_mask))\n        x = self.ln2(x + self.ffn(x))\n        return x\n\nclass DecoderLayer(nn.Module):\n    def __init__(self, n_heads, d_model, d_k, d_v, d_ff):\n        super().__init__()\n        self.self_attn = MultiHeadAttention(n_heads, d_model, d_k, d_v)\n        self.cross_attn = MultiHeadAttention(n_heads, d_model, d_k, d_v)\n        self.ffn = FeedForward(d_model, d_ff)\n        self.ln1 = nn.LayerNorm(d_model)\n        self.ln2 = nn.LayerNorm(d_model)\n        self.ln3 = nn.LayerNorm(d_model)\n\n    def forward(self, tgt, memory, tgt_mask=None, src_mask=None):\n        tgt = self.ln1(tgt + self.self_attn(tgt, tgt, tgt, tgt_mask))\n        tgt = self.ln2(tgt + self.cross_attn(tgt, memory, memory, src_mask))\n        tgt = self.ln3(tgt + self.ffn(tgt))\n        return tgt\n\nclass Encoder(nn.Module):\n    def __init__(self, vocab_size, n_heads, d_model, d_k, d_v, d_ff, n_layers):\n        super().__init__()\n        self.embed = nn.Embedding(vocab_size, d_model)\n        self.pos_enc = PositionalEncoding(d_model)\n        self.layers = nn.ModuleList([EncoderLayer(n_heads, d_model, d_k, d_v, d_ff) for _ in range(n_layers)])\n\n    def forward(self, x, src_mask=None):\n        x = self.pos_enc(self.embed(x))\n        for layer in