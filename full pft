c_pre.shape, tgt_pre.shape)\n \n# # Finetune tensors\nsrc_ft, tgt_ft = make_parallel_tensors(finetune_train_df, src_vocab, tgt_vocab, CFG[\"max_len\"])\nprint(\"Finetune tensors:\", src_ft.shape, tgt_ft.shape)\n \n# Free dataframes we no longer need\ndel pretrain_df, all_fr_tokens, all_en_tokens\ngc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T16:34:19.520148Z","iopub.execute_input":"2026-04-19T16:34:19.520493Z","iopub.status.idle":"2026-04-19T16:37:32.867480Z","shell.execute_reply.started":"2026-04-19T16:34:19.520467Z","shell.execute_reply":"2026-04-19T16:37:32.866642Z"}},"outputs":[{"name":"stdout","text":"French (src) vocab: 20000\nEnglish (tgt) vocab: 20000\nPretrain tensors: torch.Size([2252030, 128]) torch.Size([2252030, 128])\nFinetune tensors: torch.Size([317781, 128]) torch.Size([317781, 128])\n","output_type":"stream"},{"execution_count":5,"output_type":"execute_result","data":{"text/plain":"0"},"metadata":{}}],"execution_count":5},{"id":"4fab91a7","cell_type":"code","source":"def make_loaders(src_tensor, tgt_tensor, train_split, batch_size, num_workers):\n    dataset = TensorDataset(src_tensor, tgt_tensor)\n    n_train = int(train_split * len(dataset))\n    train_sub, val_sub = random_split(dataset, [n_train, len(dataset) - n_train],\n                                      generator=torch.Generator().manual_seed(SEED))\n    kw = dict(num_workers=num_workers, pin_memory=torch.cuda.is_available())\n    train_loader = DataLoader(train_sub, batch_size=batch_size, shuffle=True,  drop_last=True,  **kw)\n    val_loader   = DataLoader(val_sub,   batch_size=batch_size, shuffle=False, drop_last=False, **kw)\n    return train_loader, val_loader\n \n \npretrain_train_loader, pretrain_val_loader = make_loaders(\n    src_pre, tgt_pre, CFG[\"train_split\"], CFG[\"batch_size\"], CFG[\"num_workers\"])\nfinetune_train_loader, finetune_val_loader = make_loaders(\n    src_ft, tgt_ft, CFG[\"train_split\"], CFG[\"batch_size\"], CFG[\"num_wo