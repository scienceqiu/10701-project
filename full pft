[\"en\"].apply(clean_text)\n\n    # Rename to match your pipeline\n    df = df.rename(columns={\"fr\": \"src\", \"en\": \"tgt\"})\n\n    # Train/test split\n    train_df, test_df = train_test_split(\n        df,\n        test_size=test_size,\n        random_state=SEED,\n        shuffle=True\n    )\n\n    # Reset indices (important for dataloaders later)\n    train_df = train_df.reset_index(drop=True)\n    test_df = test_df.reset_index(drop=True)\n\n    return train_df, test_df\n\n\n# Usage\nfinetune_train_df, finetune_test_df = load_juridia_fr_en(\n    CFG[\"juridia_train\"],\n    sample_frac=CFG[\"finetune_sample_frac\"],\n    test_size=0.1\n)\n\nprint(\"Train shape:\", finetune_train_df.shape)\nprint(\"Test shape:\", finetune_test_df.shape)\nprint(finetune_train_df.head(3))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T05:36:21.579008Z","iopub.execute_input":"2026-04-19T05:36:21.579738Z","iopub.status.idle":"2026-04-19T05:36:41.628722Z","shell.execute_reply.started":"2026-04-19T05:36:21.579705Z","shell.execute_reply":"2026-04-19T05:36:41.627903Z"}},"outputs":[{"name":"stdout","text":"Train shape: (317781, 2)\nTest shape: (35309, 2)\n                                                 src  \\\n0  malgré les progrès considérables réalisés dans...   \n1  - le président , le premier ministre , le prés...   \n2  le département des délits économiques et finan...   \n\n                                                 tgt  \n0  most women in developing countries first estab...  \n1  the current government is a coalition under th...  \n2  8 . another measure adopted within the country...  \n","output_type":"stream"}],"execution_count":18},{"id":"c701d9d2","cell_type":"code","source":"\ndef build_vocab(token_lists, vocab_limit: int) -> dict:\n    counter = Counter(tok for sent in token_lists for tok in sent)\n    vocab = {\"<pad>\": 0, \"<unk>\": 1, \"<bos>\": 2, \"<eos>\": 3}\n    for tok, _ in counter.most_common(vocab_limit - 4):\n        vocab[tok] = len(vocab)\n    return vocab\n \n \ndef encode_and_pad(tokens, vocab: dict, max_len: int) -> list:\n    ids = [vocab.get(tok, vocab[\"<unk>\"]) for tok in tokens]\n    ids = [vocab[\"<bos>\"]] + ids + [vocab[\"<eos>\"]]\n    ids = ids[:max_len]\n    ids += [vocab[\"<pad>\"]] * (max_len - len(ids))\n    return ids\n \n \ndef make_parallel_tensors(df, src_vocab, tgt_vocab, max_len):\n    src_seqs = [encode_and_pad(s.split(), src_vocab, max_len) for s in df[\"src\"]]\n    tgt_seqs = [encode_and_pad(s.split(), tgt_vocab, max_len) for s in df[\"tgt\"]]\n    return (torch.tensor(src_seqs, dtype=torch.long),\n            torch.tensor(tgt_seqs, dtype=torch.long))\n \n \n# Build vocabs from pretrain corpus (French src, English tgt)\n# Include juridia text so no OOV explosion during fine-tuning\nall_fr_tokens = [s.split() for s in pd.concat(\n    [pretrain_df[\"src\"], finetune_train_df[\"src\"]], ignore_index=True)]\nall_en_tokens = [s.split() for s in pd.concat(\n    [pretrain_df[\"tgt\"], finetune_train_df[\"tgt\"]], ignore_index=True)]\n \nsrc_vocab = build_vocab(all_fr_tokens, CFG[\"src_vocab_limit\"])   # French\ntgt_vocab = build_vocab(all_en_tokens, CFG[\"tgt_vocab_limit\"])   # English\ninv_tgt_vocab = {i: w for w, i in tgt_vocab.items()}\n \nprint(f\"French (src) vocab: {len(src_vocab)}\")\nprint(f\"English (tgt) vocab: {len(tgt_vocab)}\")\n \n# Pretrain tensors\nsrc_pre, tgt_pre = make_parallel_tensors(pretrain_df, src_vocab, tgt_vocab, CFG[\"max_len\"])\nprint(\"Pretrain tensors:\", src_pre.shape, tgt_pre.shape)\n \n# # Finetune tensors\nsrc_ft, tgt_ft = make_parallel_tensors(finetune_train_df, src_vocab, tgt_vocab, CFG[\"max_len\"])\nprint(\"Finetune tensors:\", src_ft.shape, tgt_ft.shape)\n \n# Free dataframes we no longer need\ndel pretrain_df, all_fr_tokens, all_en_tokens\ngc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T05:42:04.812351Z","iopub.execute_input":"2026-04-19T05:42:04.812730Z","iopub.status.idle":"2026-04-