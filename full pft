ncoding(nn.Module):\n    def __init__(self, d_model, max_len=5000):\n        super().__init__()\n        pe = torch.zeros(max_len, d_model)\n        position = torch.arange(0, max_len, dtype=torch.float).unsqueeze(1)\n        div_term = torch.exp(torch.arange(0, d_model, 2).float() * (-math.log(10000.0) / d_model))\n        pe[:, 0::2] = torch.sin(position * div_term)\n        pe[:, 1::2] = torch.cos(position * div_term)\n        self.register_buffer(\"pe\", pe.unsqueeze(0))\n\n    def forward(self, x):\n        return x + self.pe[:, :x.size(1), :]\n\nclass AttentionLayer(nn.Module):\n    def __init__(self, d_model, d_k, d_v, r=8, lora_alpha=16):\n        super().__init__()\n        # Applied LoRA to Query, Key, and Value projections\n        self.W_q = LoRALinear(d_model, d_k, r=r, lora_alpha=lora_alpha)\n        self.W_k = LoRALinear(d_model, d_k, r=r, lora_alpha=lora_alpha)\n        self.W_v = LoRALinear(d_model, d_v, r=r, lora_alpha=lora_alpha)\n\n    def forward(self, q, k, v, mask=None):\n        Q = self.W_q(q)\n        K = self.W_k(k)\n        V = self.W_v(v)\n        scores = (Q @ K.transpose(-1, -2)) / math.sqrt(K.size(-1))\n        if mask is not None:\n            if mask.dim() == 2:\n                mask = mask.unsqueeze(0)\n            scores = scores.masked_fill(mask == 0, float('-inf'))\n        attn = torch.softmax(scores, dim=-1)\n        return attn @ V\n\nclass MultiHeadAttention(nn.Module):\n    def __init__(self, n_heads, d_model, d_k, d_v, r=8, lora_alpha=16):\n        super().__init__()\n        self.heads = nn.ModuleList([AttentionLayer(d_model, d_k, d_v, r, lora_alpha) for _ in range(n_heads)])\n        # Applied LoRA to the output projection\n        self.lin = LoRALinear(n_heads * d_v, d_model, r=r, lora_alpha=lora_alpha)\n\n    def forward(self, q, k, v, mask=None):\n        z = torch.cat([head(q, k, v, mask) for head in self.heads], dim=-1)\n        return self.lin(z)\n\nclass FeedForward(nn.Module):\n    def __init__(self, d_model, d_f